# =============================================================================
# vidgen — root environment template (T-004)
# =============================================================================
#
# Copy to `.env` (or `.env.local`) and edit. `.env*` (except this file) is
# git-ignored by `/.gitignore`. Layered loading via `@vidgen/config`:
#
#   .env  →  .env.local  →  .env.{NODE_ENV}  →  .env.{NODE_ENV}.local
#
# Every backend service validates these on boot through `@vidgen/config` and
# exits non-zero on a missing/invalid value. See `packages/config/README.md`.
#
# This file is the source of truth for env-vars consumed by services running
# on the host (e.g. `pnpm dev`). For docker-compose specifically, see
# `infra/compose/.env.example` — names match; defaults are dev-friendly here
# (localhost) and container-friendly there (service hostnames). Keep the two
# in sync when adding variables.
#
# Operational rules:
#   - Multi-tenant: every workspace_id-scoped row, bucket prefix, and queue
#     task is enforced in the application layer (arch §11).
#   - Postgres holds metadata only; media bytes live in MinIO/R2 (arch §5.1).
#   - $0 default code path. Hosted adapters are opt-in via env (arch §7.2).
#   - Never commit production secrets. `change-me` placeholders are refused
#     by @vidgen/config when NODE_ENV=production.

# ----- runtime ---------------------------------------------------------------
NODE_ENV=development
ENV=dev
LOG_LEVEL=info

# ----- API service (services/api, T-015) -------------------------------------
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
# 32+ chars of high-entropy random data. Used to sign session cookies /
# internal JWTs. Generate with: `openssl rand -hex 32`.
APP_SECRET=change-me-change-me-change-me-change-me

# ----- Postgres (T-010) ------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Service-facing user (the non-superuser `app` role created by Postgres
# init/01-app-role.sql). Services connect with these creds and have RLS
# applied. Keep in sync with the role name in 01-app-role.sql.
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vidgen
# Container superuser. Distinct from POSTGRES_USER so the app role can be
# non-superuser (so RLS actually applies — superusers bypass RLS). Used by
# migrations (T-011) and operators only; never by services.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me
# Keycloak's own database in the same Postgres instance (T-013).
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# ----- Keycloak (T-013) ------------------------------------------------------
KEYCLOAK_ADMIN=change-me
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=app
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/app
KEYCLOAK_CLIENT_ID_WEB=app-web
KEYCLOAK_CLIENT_ID_API=app-api
KEYCLOAK_CLIENT_SECRET_API=change-me

# ----- MinIO / S3-compatible object storage (T-012) --------------------------
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET_RAW=media-raw
MINIO_BUCKET_DERIVED=media-derived
MINIO_BUCKET_CHUNKS=media-chunks
MINIO_BUCKET_PUBLIC=public

# ----- Caddy (T-014) ---------------------------------------------------------
CADDY_DOMAIN=localhost
CADDY_ACME_EMAIL=change-me@example.com

# ----- Redis / DragonflyDB (T-017) -------------------------------------------
REDIS_URL=redis://localhost:6379

# ----- Temporal (T-020) ------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ----- NATS JetStream (T-022) ------------------------------------------------
NATS_URL=nats://localhost:4222

# ----- Ollama (T-070) --------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODELS=llama3.2:3b

# ----- Web / share (T-016, T-100) --------------------------------------------
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000

# ----- MCP server (services/mcp) ---------------------------------------------
MCP_PORT=3100
MCP_PUBLIC_URL=http://localhost:3100

# ----- @vidgen/config knobs --------------------------------------------------
# Set to 1 to skip dotenv-flow file loading (CI / container orchestrators that
# inject env directly).
# CONFIG_SKIP_DOTENV=1
# Override the directory dotenv-flow searches for .env* files.
# CONFIG_ENV_DIR=/absolute/path
