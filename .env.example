# =============================================================================
# vidgen — root environment template (T-004)
# =============================================================================
#
# Copy to `.env` (or `.env.local`) and edit. `.env*` (except this file) is
# git-ignored by `/.gitignore`. Layered loading via `@vidgen/config`:
#
#   .env  →  .env.local  →  .env.{NODE_ENV}  →  .env.{NODE_ENV}.local
#
# Every backend service validates these on boot through `@vidgen/config` and
# exits non-zero on a missing/invalid value. See `packages/config/README.md`.
#
# This file is the source of truth for env-vars consumed by services running
# on the host (e.g. `pnpm dev`). For docker-compose specifically, see
# `infra/compose/.env.example` — names match; defaults are dev-friendly here
# (localhost) and container-friendly there (service hostnames). Keep the two
# in sync when adding variables.
#
# Operational rules:
#   - Multi-tenant: every workspace_id-scoped row, bucket prefix, and queue
#     task is enforced in the application layer (arch §11).
#   - Postgres holds metadata only; media bytes live in MinIO/R2 (arch §5.1).
#   - $0 default code path. Hosted adapters are opt-in via env (arch §7.2).
#   - Never commit production secrets. `change-me` placeholders are refused
#     by @vidgen/config when NODE_ENV=production.

# ----- runtime ---------------------------------------------------------------
NODE_ENV=development
ENV=dev
LOG_LEVEL=info

# ----- API service (services/api, T-015) -------------------------------------
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
# 32+ chars of high-entropy random data. Used to sign session cookies /
# internal JWTs. Generate with: `openssl rand -hex 32`.
APP_SECRET=change-me-change-me-change-me-change-me

# ----- Postgres (T-010) ------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Service-facing user (the non-superuser `app` role created by Postgres
# init/01-app-role.sql). Services connect with these creds and have RLS
# applied. Keep in sync with the role name in 01-app-role.sql.
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vidgen
# Container superuser. Distinct from POSTGRES_USER so the app role can be
# non-superuser (so RLS actually applies — superusers bypass RLS). Used by
# migrations (T-011) and operators only; never by services.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me
# Optional explicit override for migrations (CI / hosted Supabase). When
# unset, services/api/src/db/migrate.ts constructs the URL from the
# POSTGRES_SUPERUSER credentials above. Format:
#   postgres://user:pass@host:port/dbname
# DATABASE_URL=
# Connection pool sizing for the runtime app-role client (T-011).
# Defaults to 10 — sufficient for a 16 GB dev box.
# POSTGRES_POOL_MAX=10
# Keycloak's own database in the same Postgres instance (T-013).
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# ----- Keycloak (T-013) ------------------------------------------------------
KEYCLOAK_ADMIN=change-me
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=app
# Issuer URL the API validates `iss` against. In Mode A this is the
# Caddy-fronted hostname so browser-issued tokens match exactly.
KEYCLOAK_ISSUER_URL=https://auth.localhost/realms/app
# Internal JWKS endpoint the API fetches over the compose network. Override
# only when running the API outside compose (e.g. `pnpm dev` on the host).
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/app/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID_WEB=app-web
KEYCLOAK_CLIENT_ID_API=app-api
KEYCLOAK_CLIENT_SECRET_API=change-me
# Comma-separated allow-list of Keycloak `azp` claim values the API accepts.
# Anything not in this list is rejected with 401 even if the signature checks.
KEYCLOAK_ALLOWED_AZP=app-web,app-api
# Host port mapped to the keycloak container's 8080. Override only if you
# already have something on 8080 locally; the in-container port stays 8080.
KEYCLOAK_HTTP_PORT=8080

# ----- MinIO / S3-compatible object storage (T-012) --------------------------
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET_RAW=media-raw
MINIO_BUCKET_DERIVED=media-derived
MINIO_BUCKET_CHUNKS=media-chunks
MINIO_BUCKET_PUBLIC=public

# ----- Caddy (T-014) ---------------------------------------------------------
# Caddy terminates HTTPS for every *.localhost subdomain (Caddy's internal CA
# mints leaf certs; the dev installs the root once — see
# infra/compose/README.md → "Trusting Caddy's local CA").
CADDY_DOMAIN=localhost
CADDY_ACME_EMAIL=change-me@example.com
# Host port mappings. Override if 80 / 443 are already taken locally; the
# in-container ports stay 80 / 443.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Caddy log level (DEBUG / INFO / WARN / ERROR / PANIC / FATAL).
CADDY_LOG_LEVEL=INFO
# Per-site upstreams consumed by infra/compose/caddy/Caddyfile. Defaults
# assume host-bound `pnpm dev` for the services without containers yet
# (web / share) and in-network service names for the services already in
# `core` (api / keycloak / minio). Override when a later ticket promotes
# a service into the compose network — e.g. once T-016 ships a `web`
# container, set APP_UPSTREAM=web:3000.
APP_UPSTREAM=host.docker.internal:3000
API_UPSTREAM=api:3001
SHARE_UPSTREAM=host.docker.internal:3002
AUTH_UPSTREAM=keycloak:8080
S3_UPSTREAM=minio:9000
MINIO_CONSOLE_UPSTREAM=minio:9001

# ----- Redis / DragonflyDB (T-017) -------------------------------------------
REDIS_URL=redis://localhost:6379
# Host port mapping for the redis (dragonfly) container. The in-container
# port stays 6379; override here only if 6379 is already taken on the host.
REDIS_PORT=6379

# ----- Temporal (T-020) ------------------------------------------------------
# Frontend gRPC address. Workers + the Temporal SDK use this for
# `Connection.connect({ address })`. Defaults to localhost for `pnpm dev`
# on the host; the compose stack reaches it as `temporal:7233`.
TEMPORAL_ADDRESS=localhost:7233
# Default namespace registered by the auto-setup container on first boot.
TEMPORAL_NAMESPACE=app
# Pinned image tags (multi-arch amd64 + arm64 verified). Renovate-friendly.
TEMPORAL_VERSION=1.29.6
TEMPORAL_UI_VERSION=2.50.0
TEMPORAL_ADMINTOOLS_VERSION=1.29.6.1-tctl-1.18.4-cli-1.7.0
# Postgres credentials Temporal uses against the existing T-010 cluster.
# The role is pre-created by `temporal-init` (LOGIN only — no SUPERUSER,
# no CREATEDB, no BYPASSRLS). Both databases are owned by this role.
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=change-me
TEMPORAL_DB_NAME=temporal
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility
# Host port mappings (in-container ports stay 7233 / 8080 — only the host
# binding changes). Override if 7233 / 8088 are already in use locally.
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8088
# Caddy upstream for `https://temporal.localhost`. In-network service name
# by default; override when the UI moves out of the compose stack (Mode B).
TEMPORAL_UI_UPSTREAM=temporal-ui:8080

# ----- NATS JetStream (T-022) ------------------------------------------------
NATS_URL=nats://localhost:4222

# ----- Ollama (T-070) --------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODELS=llama3.2:3b

# ----- Web / share (T-016, T-100) --------------------------------------------
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000
# OIDC issuer the BROWSER navigates to for sign-in (T-016). In compose this
# defaults to the Caddy-fronted https://auth.localhost so tokens carry the
# same `iss` claim the API container validates against (KEYCLOAK_ISSUER_URL
# above). On the host (pnpm dev outside compose) you may prefer the direct
# Keycloak endpoint http://localhost:8080/realms/app — if you do, also
# override the API's KEYCLOAK_ISSUER_URL to match (see api-smoke.sh).
KEYCLOAK_PUBLIC_ISSUER_URL=https://auth.localhost/realms/app
# Where the Next.js server proxies API calls to. Defaults to localhost for
# `pnpm dev`; the compose `web` service overrides to `http://api:3001`.
API_INTERNAL_URL=http://localhost:3001

# ----- MCP server (services/mcp) ---------------------------------------------
MCP_PORT=3100
MCP_PUBLIC_URL=http://localhost:3100

# ----- @vidgen/config knobs --------------------------------------------------
# Set to 1 to skip dotenv-flow file loading (CI / container orchestrators that
# inject env directly).
# CONFIG_SKIP_DOTENV=1
# Override the directory dotenv-flow searches for .env* files.
# CONFIG_ENV_DIR=/absolute/path
