# vidgen — Docker Compose env template (T-003)
#
# Copy to `.env` (or `.env.local`) and edit. `.env*` (except this file) is
# git-ignored. Every value is intentionally `change-me` so that misconfigured
# deployments fail loudly. Later tickets will add the services that consume
# these variables; this file is the single source of truth for var names.
#
# Service mapping (filled in by later tickets):
#   POSTGRES_*    -> T-010 Postgres
#   MINIO_*       -> T-012 MinIO
#   KEYCLOAK_*    -> T-013 Keycloak
#   CADDY_*       -> T-014 Caddy
#   REDIS_*       -> T-017 DragonflyDB
#   TEMPORAL_*    -> T-020 Temporal
#   NATS_*        -> T-022 NATS JetStream
#   OLLAMA_*      -> T-070 Ollama
#
# Operational notes:
#   - Multi-tenant: every workspace_id-scoped row, bucket prefix, and queue
#     task is enforced in the application layer (architecture.md §11).
#   - Postgres holds metadata only; media bytes live in MinIO/R2 (arch §5.1).
#   - Default code path = $0 (local/OSS). Hosted adapters are opt-in via env.

# ----- runtime ----------------------------------------------------------------
ENV=dev
LOG_LEVEL=info
COMPOSE_PROJECT_NAME=vidgen

# ----- Postgres (T-010) -------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Service-facing user (the non-superuser `app` role created by
# init/01-app-role.sql). Services connect with these creds and have RLS
# applied. Keep in sync with the role name in 01-app-role.sql.
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vidgen
# Container superuser. Distinct from POSTGRES_USER so the app role can be
# non-superuser (so RLS actually applies — superusers bypass RLS). Used by
# migrations (T-011) and operators only.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me
# Keycloak gets its own database in the same Postgres instance (T-013).
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# ----- MinIO (T-012) ----------------------------------------------------------
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
# Bucket names (arch §5.1). These are conventions, not secrets.
MINIO_BUCKET_RAW=media-raw
MINIO_BUCKET_DERIVED=media-derived
MINIO_BUCKET_CHUNKS=media-chunks
MINIO_BUCKET_PUBLIC=public

# ----- Keycloak (T-013) -------------------------------------------------------
KEYCLOAK_ADMIN=change-me
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=app
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/app
KEYCLOAK_CLIENT_ID_WEB=app-web
KEYCLOAK_CLIENT_ID_API=app-api
KEYCLOAK_CLIENT_SECRET_API=change-me

# ----- Caddy (T-014) ----------------------------------------------------------
CADDY_DOMAIN=localhost
CADDY_ACME_EMAIL=change-me@example.com

# ----- Redis / DragonflyDB (T-017) -------------------------------------------
REDIS_URL=redis://redis:6379

# ----- Temporal (T-020) -------------------------------------------------------
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default

# ----- NATS JetStream (T-022) -------------------------------------------------
NATS_URL=nats://nats:4222

# ----- Ollama (T-070) ---------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODELS=llama3.2:3b

# ----- API / Web (T-015, T-016) ----------------------------------------------
API_PORT=3001
WEB_PORT=3000
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000
# 32+ char random string used to sign session cookies / internal JWTs.
APP_SECRET=change-me
