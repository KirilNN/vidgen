{
  "name": "vidgen",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source, $0-cost, Docker-first video creation platform. See docs/architecture.md.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.11.0 <23",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.1",
    "turbo": "^2.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
