{
  "name": "@vidgen/openapi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi.yaml": "./openapi.yaml"
  },
  "files": [
    "src",
    "openapi.yaml"
  ],
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit -p tsconfig.json",
