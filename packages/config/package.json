    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "dotenv-flow": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
