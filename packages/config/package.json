{
  "name": "@vidgen/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/services/api.ts",
    "./worker": "./src/services/worker.ts",
    "./mcp": "./src/services/mcp.ts",
    "./web": "./src/services/web.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit -p tsconfig.json",
